{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yellow-vpn",
  "version": "0.1.3",
  "identifier": "com.ff15.yellow-vpn",
  "build": {
    "beforeDevCommand": "bun run fetch:wintun && bun run predev:helper && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run fetch:wintun && bun run prebuild:helper && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yellow VPN",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "shadow": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yellow-vpn-helper"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  }
}
