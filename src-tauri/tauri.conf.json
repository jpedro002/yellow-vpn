{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yellow-vpn",
  "version": "0.1.0",
  "identifier": "com.ff15.yellow-vpn",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "yellow-vpn",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/wintun.dll",
      "resources/yellow-vpn-helper.exe"
    ]
  }
}
